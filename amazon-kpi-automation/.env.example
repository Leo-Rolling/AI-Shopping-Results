# Amazon KPI Automation - Environment Variables
# Copy this file to .env and fill in the values

# =============================================================================
# Google Cloud Configuration
# =============================================================================

# GCP Project ID
GCP_PROJECT_ID=sellerboard-amz-kpi

# Use environment variables for secrets instead of Secret Manager (for local dev)
USE_ENV_SECRETS=true

# =============================================================================
# Sellerboard Credentials (when USE_ENV_SECRETS=true)
# =============================================================================

# JSON format: {"email": "your-email@example.com", "password": "your-password"}
SELLERBOARD_CREDENTIALS={"email": "", "password": ""}

# =============================================================================
# Google Service Account (when USE_ENV_SECRETS=true)
# =============================================================================

# Paste the entire service account JSON as a single line
# Or set path to service account file:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
GOOGLE_SERVICE_ACCOUNT=

# =============================================================================
# Google Drive Configuration
# =============================================================================

# Target folder ID for generated reports
GOOGLE_DRIVE_FOLDER_ID=1QR55nVzPpY9bUMzydI7CkSMPY4HLPGzM

# =============================================================================
# Amazon SP-API Credentials (when USE_ENV_SECRETS=true)
# =============================================================================

# JSON format: {"refresh_token": "Atzr|...", "lwa_app_id": "amzn1.application-oa2-client.xxx", "lwa_client_secret": "amzn1.oa2-cs.v1.xxx", "aws_access_key": "AKIA...", "aws_secret_key": "...", "role_arn": "arn:aws:iam::123456789:role/sp-api-role"}
SP_API_CREDENTIALS_EU_UK=
SP_API_CREDENTIALS_NA=

# =============================================================================
# Application Configuration
# =============================================================================

# Flask/Gunicorn port
PORT=8080

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Browser mode (set to false for debugging)
HEADLESS=true
